{
  "name": "@maestro/server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:ui": "vite build",
    "clean": "rm -rf dist dist-ui",
    "dev": "concurrently \"ts-node src/index.ts\" \"vite\"",
    "dev:server": "ts-node src/index.ts",
    "dev:ui": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@maestro/core": "*",
    "express": "^4.18.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "concurrently": "^8.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^1.6.0"
  }
}
